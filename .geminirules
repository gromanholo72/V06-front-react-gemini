# -------------------------------------------------------------
# 🔄 PADRÃO SINCRETISTA FRONT/BACK (SALVAMENTO VPS) - SAGRADO 📐
# -------------------------------------------------------------

Este padrão define como o Front-end e o Back-end (VPS) devem colaborar para salvar dados de cards. O Front-end usa `Cnpj.jsx` como referência e o Back-end usa a rota `/atualizar-empresa`. Quando o usuário fornecer apenas o `payload` (mapeamento de dados), todo o restante do fluxo deve ser gerado automaticamente seguindo estas estruturas.

## 1️⃣ FRONT-END: Estrutura Obrigatória da Função `async`

- Toda função de salvamento via POST para a VPS DEVE seguir exatamente este fluxo lógico e visual, usando os Emojis específicos do bloco de dados (ex: 🏢 para Empresa, 📍 para Endereço, etc.).

```javascript
const salvarDados[NomeDoBloco] = async () => {

    // A - Logs de Início (Estruturados com Emojis do Bloco)
    console.log("");
    console.log("💾 [Emoji] ------------------------------");
    console.log("💾 [Emoji] INICIANDO SALVAMENTO:");
    console.log(`💾 [Emoji] Componente - [NomeDoComponente].jsx`);
    console.log(`💾 [Emoji] Funcao: salvarDados[NomeDoBloco]()`);
    console.log("💾 [Emoji] -------------------------------");

    // B - Trava de Concorrência e UX Inicial
    if (carregandoOperacao) return; 
    window.scrollTo({ top: 0, behavior: 'smooth' });
    setMsg({ tipo: '', texto: '' });
    setCarregandoOperacao(true); 

    try {
        // C - Extração e Validação do CPF (dadosToken)
        const cpfLimpo = dadosToken?.cpef ? dadosToken.cpef.replace(/\D/g, "") : "";
        
        if (!cpfLimpo) {
            console.error("✨ [Emoji] 🛑 Falha crítica: CPF não encontrado para salvar nos cards.");
            //setMsg({ tipo: 'erro', texto: '🛑 CPF não identificado.' }); // Opcional
            return; // Aborta
        }

        // D - Logs de Identidade
        console.log("");
        console.log("💾 [Emoji] -------------------------------");
        console.log("💾 [Emoji] 🔍 EXTRAÇÃO DE IDENTIDADE:");
        console.log(`💾 [Emoji] 🛰️ Componente - [NomeDoComponente].jsx`);
        console.log("💾 [Emoji] 🆔 cpfLimpo (para URL):", cpfLimpo);
        console.log("💾 [Emoji] 🌐 URL_SERVIDOR:", URL_SERVIDOR);
        console.log("💾 [Emoji] -------------------------------");

        // E - Preparação do Payload (FORNECIDO PELO USUÁRIO)
        // O usuário fornece apenas este bloco abaixo.
        /* const payload = {
            cpef: cpfLimpo,
            [NomeDoNoNoBanco]: { 
                campo1Banco: estado1Front,
                campo2Banco: estado2Front,
                // ...
            }
        };
        */
        // [O Gemini insere o payload fornecido aqui]

        // F - Logs do Payload (Preparação)
        console.log("");
        console.log("📐 ----------------------------------");
        console.log(`📐 📦 DADOS PREPARADOS PARA ENVIO ([NomeDoBloco]):`);
        console.log(`📐 componente - [NomeDoComponente].jsx`);
        console.log("📐 payload:", payload);
        console.log("📐 ----------------------------------");

        // G - UX: Tempo Mínimo de Loading (500ms a 1s) para feedback visual
        const tempoMinimo = new Promise(resolve => setTimeout(resolve, 800));

        // H - Transmissão Assíncrona (fetch POST)
        const requisicao = fetch(`${URL_SERVIDOR}/atualizar-[rota-vps]`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });

        // I - Espera Paralela (Resposta + Tempo Mínimo)
        const [resposta] = await Promise.all([requisicao, tempoMinimo]);
        const resultado = await resposta.json();

        // J - Tratamento do Resultado (Sucesso/Rejeição VPS)
        if (resposta.ok) {
            // Logs de Sucesso
            console.log("");
            console.log("💾 📡 -----------------------------------------------------------");
            console.log("💾 📡 Resposta do Servidor OK");
            console.log(`💾 [Emoji] Componente - [NomeDoComponente].jsx`);
            console.log("💾 📡 Status : ✅ Sincronizado");
            console.log("💾 📡 -----------------------------------------------------------");

            setMsg({ tipo: 'sucesso', texto: '✅ Dados atualizados com sucesso!' });

            // Recarrega dados para travar edição
            carregarDadosDoBanco();

        } else {
            // Logs de Rejeição do Servidor
            console.warn("💾 ⚠️ SERVIDOR REJEITOU:", resultado.erro);
            setMsg({ tipo: 'erro', texto: resultado.erro });
        }

    } catch (error) {
        // K - Tratamento de Falha Crítica (Conexão)
        console.error("💾 🚨 FALHA CRÍTICA NO PROCESSO:");
        console.error("💾 🚨 Detalhes:", error);
        setMsg({ tipo: 'erro', texto: '❌ Erro de conexão com o servidor VPS.' });

    } finally {
        // L - Finalização Obrigatória
        setCarregandoOperacao(false);
        temporizadorMSG();
    }
};









// [Emoji] ROTA NA VPS PARA ATUALIZAR [NomeDoBloco]
// Recebe POST do componente [NomeDoComponente].jsx
app.post('/atualizar-[rota-vps]', async (req, res) => {
    
    // A - Desestruturação do Pacote (Payload) recebido
    const { cpef, [NomeDoNoNoBanco] } = req.body;

    console.log("");
    console.log("📥 [Emoji] -----------------------------------------------------------");
    console.log(`📥 [Emoji] REQUISIÇÃO RECEBIDA NA VPS: POST /atualizar-[rota-vps]`);
    console.log(`📥 [Emoji] Origem: Componente [Emoji] [NomeDoComponente].jsx`);
   

    // B - 🛡️ Validação de Segurança Básica: CPF é obrigatório
    if (!cpef) {
        console.warn("📥 🛑 ⚠️ ALERTA VPS: Tentativa de atualização sem CPF barrada.");
        return res.status(400).json({ erro: "CPF não identificado na requisição." });
    }

    // C - 🛡️ Validação de Integridade (Padrão Maestro): Verificar campo obrigatório do bloco
    // O Gemini deve inferir o campo obrigatório principal (ex: cnpj, cep, nivel)
    if (![NomeDoNoNoBanco] || ![NomeDoNoNoBanco].[CampoObrigatório]) {
        console.warn(`📥 🛑 ⚠️ ALERTA VPS [CPF: ${cpef}]: Dados obrigatórios de [NomeDoBloco] ausentes.`);
        return res.status(400).json({ erro: "⚠️ Dados obrigatórios ausentes!" });
    }

    try {
        // D - Log de Processamento
        console.log(`📥 [Emoji] VPS: Processando atualização de dados de [NomeDoBloco] do CPF [${cpef}]`);
    
        // E - Conexão Admin SDK (Poder Total)
        const usuarioRef = db_admin.ref(`usuarios/${cpef}`);
        
        // F - Gravação com update() (Preserva nós vizinhos)
        await usuarioRef.update({
            [NomeDoNoNoBanco]: [NomeDoNoNoBanco] 
        });

        // G - Logs de Sucesso na VPS
        console.log(`📥 [Emoji] ✅ Gravação de Dados de [NomeDoBloco] concluída com sucesso na Antena Central.`);
        console.log(`📥 [Emoji] ✅ Dados gravados:`, [NomeDoNoNoBanco]);
        console.log("📥 [Emoji] -----------------------------------------------------------");
        
        // H - Resposta de Sucesso (Padrão Maestro)
        return res.status(200).json({ 
            status: "sucesso",
            mensagem: "✅ Dados sincronizados na Antena Central."
        });

    } catch (error) {
        // I - 🔥 TRATAMENTO DE ERRO CRÍTICO NA VPS
        console.log("📥 🔥 -----------------------------------------------------------");
        console.error(`📥 🔥 ERRO CRÍTICO NA VPS (Processamento de [NomeDoBloco]):`);
        console.error(`📥 🔥 CPF Alvo: ${cpef}`);
        console.error("📥 🔥 Detalhes:", error.message);
        console.log("📥 🔥 -----------------------------------------------------------");

        // Retorna erro 500 padronizado para o front-end
        return res.status(500).json({ 
            erro: "Erro interno no servidor VPS ao processar a atualização." 
        });
    }
});












